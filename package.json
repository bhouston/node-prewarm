{
  "name": "node-prewarm",
  "version": "0.3.0",
  "description": "Pre-warm Node's stable module compile cache by starting a server, waiting for a port, then shutting down",
  "keywords": [
    "compile-cache",
    "docker",
    "node",
    "prewarm"
  ],
  "license": "MIT",
  "author": "Ben Houston (ben@ben3d.ca)",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhouston/node-prewarm"
  },
  "bin": {
    "node-prewarm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/prewarm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/prewarm.d.ts",
      "default": "./dist/prewarm.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "make-release": "node scripts/make-release.mjs ."
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.6",
    "express": "^5.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-command-line": "^0.7.0"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@11.0.8"
}
